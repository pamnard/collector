{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Collector",
  "version": "0.1.7",
  "identifier": "com.collector.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Collector",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "shortDescription": "Offline-first desktop vault for saved content",
    "longDescription": "Collector is an offline-first desktop app for saving and organizing articles, images, videos, notes, bookmarks, and more. Files on disk are the source of truth; SQLite powers search and filters.",
    "publisher": "pamnard",
    "copyright": "Copyright (c) 2026 pamnard. MIT License.",
    "homepage": "https://github.com/pamnard/collector",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MENBQjk5MzVBQzE4OEQKUldTTkdLdzFtYXNNZGk2cC9BbVJKS3FsTmg2cnc1QmVJazZDNkNjRm9MK281a1YwWDB6MSt0dXEK",
      "endpoints": [
        "https://github.com/pamnard/collector/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
