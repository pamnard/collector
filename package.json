{
  "name": "collector",
  "private": true,
  "version": "0.1.17",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build:packages": "npm run build --workspace @collector/shared && npm run build --workspace @collector/db && npm run build --workspace @collector/core",
    "build": "npm run build:packages && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "npm run typecheck --workspace @collector/shared && npm run typecheck --workspace @collector/db && npm run typecheck --workspace @collector/core && tsc --noEmit",
    "test": "npm run test --workspace @collector/db && npm run test --workspace @collector/core",
    "test:startup": "npm run build:packages && node scripts/startup-index-smoke.mjs",
    "test:vault-index": "npm run build:packages && node scripts/vault-index-rebuild-smoke.mjs",
    "test:large-empty-index": "npm run build:packages && node scripts/large-vault-empty-index-smoke.mjs",
    "verify:release": "bash scripts/verify-release.sh",
    "tauri": "tauri",
    "tauri:dev": "bash scripts/tauri-dev.sh"
  },
  "dependencies": {
    "@collector/core": "*",
    "@collector/db": "*",
    "@collector/shared": "*",
    "@fontsource/golos-text": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.17",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
