{
  "name": "collector",
  "private": true,
  "version": "0.1.23",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build:packages": "npm run build --workspace @collector/shared && npm run build --workspace @collector/api && npm run build --workspace @collector/db && npm run build --workspace @collector/core && npm run build --workspace @collector/service",
    "build": "npm run build:packages && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "npm run typecheck --workspace @collector/shared && npm run typecheck --workspace @collector/api && npm run typecheck --workspace @collector/db && npm run typecheck --workspace @collector/core && npm run typecheck --workspace @collector/service && tsc --noEmit",
    "test": "npm run test --workspace @collector/db && npm run test --workspace @collector/core && npm run test --workspace @collector/service",
    "test:startup": "npm run build:packages && node scripts/startup-index-smoke.mjs",
    "test:vault-index": "npm run build:packages && node scripts/vault-index-rebuild-smoke.mjs",
    "test:large-empty-index": "npm run build:packages && node scripts/large-vault-empty-index-smoke.mjs",
    "test:service-host": "npm run build:packages && node scripts/service-host-health-smoke.mjs",
    "verify:release": "bash scripts/verify-release.sh",
    "tauri": "tauri",
    "tauri:dev": "bash scripts/tauri-dev.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@collector/api": "*",
    "@collector/core": "*",
    "@collector/db": "*",
    "@collector/service": "*",
    "@collector/shared": "*",
    "@fontsource/golos-text": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-masonry-css": "^1.0.16",
    "react-resizable-panels": "^4.12.2",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.17",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
