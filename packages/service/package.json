{
  "name": "@collector/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "collector-service": "./dist/host/cli.js"
  },
  "exports": {
    ".": {
      "@collector/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./host": {
      "@collector/source": "./src/host-entry.ts",
      "types": "./dist/host-entry.d.ts",
      "import": "./dist/host-entry.js"
    },
    "./ipc": {
      "@collector/source": "./src/ipc-entry.ts",
      "types": "./dist/ipc-entry.d.ts",
      "import": "./dist/ipc-entry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "serve": "node ./dist/host/cli.js serve"
  },
  "dependencies": {
    "@collector/api": "*",
    "@collector/core": "*",
    "@collector/db": "*",
    "@collector/shared": "*",
    "better-sqlite3": "^11.9.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "~5.8.3",
    "vitest": "^3.0.9"
  }
}
